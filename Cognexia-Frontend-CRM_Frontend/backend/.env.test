# Industry 5.0 ERP Backend - Test Environment Configuration
# Environment variables for test runs
# Author: AI Assistant
# Date: 2024

NODE_ENV=test

# Test Database Configuration
TEST_DB_TYPE=postgres
TEST_DB_HOST=localhost
TEST_DB_PORT=5433
TEST_DB_USERNAME=industry5_test_user
TEST_DB_PASSWORD=industry5_test_password
TEST_DB_DATABASE=industry5_test_db

# Alternative: Use SQLite in-memory database for testing
# TEST_DB_TYPE=sqlite
# TEST_DB_DATABASE=:memory:

# JWT Configuration (Test values)
JWT_SECRET=test_jwt_secret_key_for_testing_only
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=test_refresh_secret_key_for_testing_only
JWT_REFRESH_EXPIRES_IN=7d

# Redis Configuration (Test)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=1

# Logging Configuration
LOG_LEVEL=error
LOG_FILE=false

# Email Configuration (Mock)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test@company.com
SMTP_PASSWORD=test_password
SMTP_FROM=noreply@company.com

# File Upload Configuration (Test)
UPLOAD_DIR=./test/uploads
MAX_FILE_SIZE=10MB

# Security Configuration (Test)
BCRYPT_ROUNDS=4
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=1000

# External Services (Mock URLs)
BLOCKCHAIN_NODE_URL=http://localhost:8545
MQTT_BROKER_URL=mqtt://localhost:1883
AI_SERVICE_URL=http://localhost:3001

# Test-specific flags
SKIP_MIGRATIONS=false
AUTO_CREATE_SCHEMA=true
RESET_DB_ON_START=true
