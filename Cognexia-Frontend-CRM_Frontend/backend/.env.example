# Industry 5.0 ERP Backend Environment Configuration

# Application Settings
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database Configuration - Multi-Database Architecture
# PostgreSQL for Core ERP Modules (Users, Organizations, Production, Quality, etc.)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Cognexiai
POSTGRES_DB=industry5_erp
POSTGRES_SSL=false

# Supabase Configuration (Cloud PostgreSQL Alternative)
# Get credentials from: https://supabase.com/dashboard/project/_/settings/database
USE_SUPABASE=false  # Set to 'true' to use Supabase instead of local PostgreSQL
SUPABASE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
SUPABASE_DB_HOST=db.[PROJECT-REF].supabase.co
SUPABASE_DB_PASSWORD=your_supabase_password
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Hybrid Database Mode (Dual-Write to both Local and Supabase)
ENABLE_DUAL_WRITE=false  # Set to 'true' to write to both databases simultaneously

# MongoDB for Advanced Supply Chain & IoT Data
MONGODB_URI=mongodb://localhost:27017/industry5_supply_chain

# Redis for Caching, Sessions & Real-time Data
REDIS_URL=redis://localhost:6379

# Cross-Module Integration Settings
CROSS_MODULE_INTEGRATION=true
EVENT_PROCESSING_ENABLED=true
REAL_TIME_SYNC=true
INTEGRATION_QUEUE_SIZE=1000
EVENT_PROCESSING_INTERVAL=1000

# Security Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_here
JWT_EXPIRATION=24h
BCRYPT_ROUNDS=12

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Advanced Supply Chain - IoT Configuration
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=iot_user
MQTT_PASSWORD=iot_password
IOT_DEVICE_REGISTRY_URL=http://localhost:8080

# Advanced Supply Chain - AI Configuration
AI_MODEL_ENDPOINT=http://localhost:5000
TENSORFLOW_GPU_ENABLED=false
AI_PREDICTION_CONFIDENCE_THRESHOLD=0.7
AI_ANOMALY_DETECTION_SENSITIVITY=0.8

# Advanced Supply Chain - Blockchain Configuration
BLOCKCHAIN_NETWORK=http://localhost:8545
SUPPLY_CHAIN_CONTRACT=0x1234567890123456789012345678901234567890
TRACEABILITY_CONTRACT=0x0987654321098765432109876543210987654321
QUALITY_CONTRACT=0xabcdefabcdefabcdefabcdefabcdefabcdefabcd
COMPLIANCE_CONTRACT=0xfedcbafedcbafedcbafedcbafedcbafedcbafedcba
BLOCKCHAIN_GAS_LIMIT=2000000

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
CDN_URL=https://your-cdn-url.com

# External Service Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=industry5-erp-files

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
# Twilio Verify Service SID (for MFA SMS) - create at https://console.twilio.com/us1/develop/verify/services
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Set to 'true' to use local OTP instead (OTP shown in response) - use when Verify Service is misconfigured
# TWILIO_SMS_USE_LOCAL=true

# Monitoring Configuration
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9464
GRAFANA_ENABLED=true
ELASTICSEARCH_URL=http://localhost:9200
KIBANA_URL=http://localhost:5601

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_CREATE_MAX=10

# Cache TTL Settings (in seconds)
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=1800
CACHE_TTL_LONG=3600

# WebSocket Configuration
WEBSOCKET_ENABLED=true
WEBSOCKET_PING_TIMEOUT=5000
WEBSOCKET_PING_INTERVAL=25000

# Module Configuration - Enable/Disable Modules
SUPPLY_CHAIN_ENABLED=true
PRODUCTION_PLANNING_ENABLED=true
MANUFACTURING_ENABLED=true
QUALITY_MANAGEMENT_ENABLED=true
SHOP_FLOOR_CONTROL_ENABLED=true
MAINTENANCE_ENABLED=true
PROCUREMENT_ENABLED=true
INTEGRATION_GATEWAY_ENABLED=true

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_DB_ENABLED=true
HEALTH_CHECK_CACHE_ENABLED=true
HEALTH_CHECK_EXTERNAL_ENABLED=true
