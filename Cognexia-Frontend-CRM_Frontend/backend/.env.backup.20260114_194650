# ========================================
# Industry 5.0 ERP - Self-Contained Configuration
# No External APIs Required - Fully Autonomous System
# ========================================

# OpenRouter API Key (If Needed for Future Use)
OPENROUTER_API_KEY=
Port=5000
# Environment Configuration
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# ========================================
# DATABASE CONFIGURATION (LOCAL ONLY)
# ========================================
# Primary Database (SQLite for development)
DB_TYPE=sqlite
DB_DATABASE=./database/industry5.db
DB_SYNCHRONIZE=true
DB_LOGGING=false
DB_RETRY_ATTEMPTS=3
DB_RETRY_DELAY=3000

# MongoDB (For Analytics & Logs)
MONGO_URI=mongodb://localhost:27017/industry5_analytics
MONGO_ENABLED=false

# Redis (Caching & Sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ENABLED=false
REDIS_TTL=3600

# ========================================
# SECURITY & AUTHENTICATION (LOCAL)
# ========================================
JWT_SECRET=Industry5ERP_SuperSecure_LocalJWT_Key_2024_ChangeMeInProduction
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=Industry5ERP_RefreshToken_SecureKey_2024_ChangeMeInProduction
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# CORS Configuration
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080,http://localhost:4200

# ========================================
# LOCAL AI/ML SERVICES (NO EXTERNAL APIS)
# ========================================
AI_ENABLED=true
AI_PROVIDER=local
AI_LOCAL_MODELS_PATH=./ai-models
AI_TENSORFLOW_ENABLED=true
AI_NLP_ENABLED=true
AI_SENTIMENT_ANALYSIS=true
AI_TEXT_CLASSIFICATION=true
AI_PREDICTIVE_ANALYTICS=true

# Local AI Model Configuration
AI_MODEL_CACHE_SIZE=500
AI_INFERENCE_TIMEOUT=30000
AI_BATCH_SIZE=32

# ========================================
# LOCAL FILE STORAGE (NO CLOUD SERVICES)
# ========================================
FILE_STORAGE_TYPE=local
FILE_UPLOAD_PATH=./storage/uploads
FILE_DOCUMENTS_PATH=./storage/documents
FILE_IMAGES_PATH=./storage/images
FILE_REPORTS_PATH=./storage/reports
FILE_BACKUPS_PATH=./storage/backups
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,csv,txt

# Image Processing (Local)
IMAGE_PROCESSING_ENABLED=true
IMAGE_RESIZE_ENABLED=true
IMAGE_THUMBNAIL_SIZE=200
IMAGE_QUALITY=85

# ========================================
# LOCAL EMAIL SYSTEM (FILE-BASED SIMULATION)
# ========================================
EMAIL_ENABLED=true
EMAIL_PROVIDER=local
EMAIL_SIMULATION_PATH=./storage/emails
EMAIL_FROM_NAME=Industry 5.0 ERP System
EMAIL_FROM_ADDRESS=noreply@industry5erp.local
EMAIL_TEMPLATE_PATH=./templates/emails

# ========================================
# IOT & SENSOR SIMULATION (LOCAL)
# ========================================
IOT_ENABLED=true
IOT_SIMULATION_MODE=true
IOT_PROTOCOLS=mqtt,websocket,http
IOT_MQTT_BROKER=mqtt://localhost:1883
IOT_WEBSOCKET_PORT=3001
IOT_DATA_RETENTION_DAYS=90

# Sensor Simulation
IOT_SENSOR_COUNT=50
IOT_SENSOR_INTERVAL=5000
IOT_SENSOR_TYPES=temperature,pressure,vibration,humidity,flow,level

# ========================================
# LOCAL BLOCKCHAIN (PRIVATE NETWORK)
# ========================================
BLOCKCHAIN_ENABLED=true
BLOCKCHAIN_NETWORK=local
BLOCKCHAIN_PRIVATE_KEY=0x1234567890123456789012345678901234567890123456789012345678901234
BLOCKCHAIN_CONTRACT_ADDRESS=0x1234567890123456789012345678901234567890
BLOCKCHAIN_GAS_LIMIT=6721975
BLOCKCHAIN_GAS_PRICE=20000000000

# ========================================
# LOGGING & MONITORING (LOCAL)
# ========================================
LOG_LEVEL=debug
LOG_FILE_ENABLED=true
LOG_CONSOLE_ENABLED=true
LOG_PATH=./logs
LOG_MAX_FILES=7
LOG_MAX_SIZE=10m

# Metrics & Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics
HEALTH_CHECK_ENABLED=true

# ========================================
# MANUFACTURING & PRODUCTION
# ========================================
MANUFACTURING_ENABLED=true
PRODUCTION_SIMULATION=true
QUALITY_CONTROL_ENABLED=true
MAINTENANCE_SCHEDULING=true

# ========================================
# BUSINESS MODULES CONFIGURATION
# ========================================
HR_MODULE_ENABLED=true
CRM_MODULE_ENABLED=true
INVENTORY_MODULE_ENABLED=true
PROCUREMENT_MODULE_ENABLED=true
ANALYTICS_MODULE_ENABLED=true
DIGITAL_TWIN_ENABLED=true
QUANTUM_SIMULATION_ENABLED=false

# ========================================
# DEVELOPMENT & TESTING
# ========================================
DEBUG_MODE=true
SWAGGER_ENABLED=true
API_DOCUMENTATION_PATH=/api/docs
SEED_DATA_ENABLED=true
TEST_DATA_ENABLED=true

# Performance Settings
MAX_CONCURRENT_REQUESTS=1000
REQUEST_TIMEOUT=30000
DATABASE_POOL_SIZE=20

# ========================================
# BACKUP & RECOVERY (LOCAL)
# ========================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./storage/backups
AUTO_BACKUP_ON_STARTUP=true
