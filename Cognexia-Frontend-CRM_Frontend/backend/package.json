{
  "name": "@industry5-erp/backend",
  "version": "1.0.0",
  "description": "Industry 5.0 ERP Backend API Server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "ts-node --esm src/main.ts",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:full": "ts-node start-backend.ts",
    "clean": "rimraf dist",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:hr": "jest --testPathPattern=hr --passWithNoTests",
    "test:hr:watch": "jest --testPathPattern=hr --watch",
    "test:hr:coverage": "jest --testPathPattern=hr --coverage",
    "test:integration": "jest --testNamePattern='Integration Tests' --passWithNoTests",
    "test:e2e": "jest --testNamePattern='End-to-End' --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "db:migrate": "typeorm migration:run",
    "db:migrate:revert": "typeorm migration:revert",
    "db:generate": "typeorm migration:generate",
    "db:seed": "ts-node src/database/seeds/index.ts",
    "migrate:hr": "ts-node scripts/migrate-hr.ts",
    "migrate:hr:run": "ts-node scripts/migrate-hr.ts run",
    "migrate:hr:rollback": "ts-node scripts/migrate-hr.ts rollback",
    "migrate:hr:status": "ts-node scripts/migrate-hr.ts status",
    "migrate:hr:refresh": "ts-node scripts/migrate-hr.ts refresh",
    "seed:hr": "ts-node src/database/seeds/hr-seed-runner.ts",
    "seed:hr:run": "ts-node src/database/seeds/hr-seed-runner.ts run",
    "seed:hr:clear": "ts-node src/database/seeds/hr-seed-runner.ts clear",
    "seed:hr:refresh": "ts-node src/database/seeds/hr-seed-runner.ts refresh",
    "manufacturing:setup": "ts-node scripts/setup-manufacturing-db.ts",
    "manufacturing:setup:dev": "ts-node scripts/setup-manufacturing-db.ts development",
    "manufacturing:setup:test": "ts-node scripts/setup-manufacturing-db.ts test",
    "manufacturing:setup:all": "ts-node scripts/setup-manufacturing-db.ts all",
    "manufacturing:db:setup": "ts-node scripts/setup-local-postgres.ts",
    "manufacturing:db:up": "docker-compose -f docker-compose.manufacturing.yml up -d",
    "manufacturing:db:down": "docker-compose -f docker-compose.manufacturing.yml down",
    "manufacturing:db:reset": "docker-compose -f docker-compose.manufacturing.yml down -v && docker-compose -f docker-compose.manufacturing.yml up -d",
    "manufacturing:test": "jest --testPathPattern=manufacturing --passWithNoTests",
    "manufacturing:test:watch": "jest --testPathPattern=manufacturing --watch",
    "manufacturing:test:coverage": "jest --testPathPattern=manufacturing --coverage",
    "supabase:setup": "ts-node src/manufacturing/scripts/setup-supabase.ts setup",
    "supabase:health": "ts-node src/manufacturing/scripts/setup-supabase.ts health",
    "supabase:test": "ts-node src/manufacturing/scripts/setup-supabase.ts health",
    "manufacturing:supabase:setup": "ts-node src/manufacturing/scripts/setup-supabase.ts setup",
    "manufacturing:supabase:health": "ts-node src/manufacturing/scripts/setup-supabase.ts health",
    "swagger": "swagger-jsdoc -d src/swagger.config.js -o swagger.json src/routes/*.ts"
  },
