    "semantic-segmentation": "^1.0.0",
    "pose-estimation": "^1.0.0",
    "ocr-engine": "^1.0.0",
    "reflect-metadata": "^0.1.13"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "jest": "^29.5.0",
    "typescript": "^5.1.3"
  },
  "keywords": ["computer-vision", "image-recognition", "object-detection", "ocr", "face-recognition", "ai", "deep-learning", "industry5.0"],
