{
  "name": "@ezai-mfg-ninja/adaptive-analytics",
  "version": "1.0.0",
  "description": "Industry 5.0 Adaptive Analytics Module - Self-learning analytics engine with real-time adaptation, predictive modeling, and autonomous insight generation for manufacturing intelligence",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/index.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start:debug": "node --inspect-brk -r ts-node/register src/index.ts",
    "start:prod": "node dist/index.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsnode/register -r tsconfig-paths/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:ml": "jest --config ./test/jest-ml.json",
    "train": "ts-node scripts/train-models.ts",
    "predict": "ts-node scripts/run-predictions.ts",
    "benchmark": "ts-node scripts/benchmark-models.ts",
    "migrate:ml": "ts-node scripts/migrate-ml-models.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "precommit": "lint-staged",
    "serve:tensorboard": "tensorboard --logdir=./logs/tensorboard",
    "serve:mlflow": "mlflow ui --backend-store-uri=./mlruns"
  },
  "keywords": [
    "adaptive-analytics",
    "machine-learning",
    "deep-learning",
    "predictive-analytics",
    "real-time-analytics",
    "self-learning",
    "autonomous-insights",
    "manufacturing-intelligence",
    "time-series-forecasting",
    "anomaly-detection",
    "pattern-recognition",
    "neural-networks",
    "reinforcement-learning",
    "automl",
    "industry-5.0",
    "nestjs",
    "tensorflow",
    "pytorch",
    "typescript"
  ],
  "author": {
    "name": "EzAi MfgNinja Team",
    "email": "adaptive-analytics@ezai-mfgninja.com",
    "url": "https://ezai-mfgninja.com"
  },
