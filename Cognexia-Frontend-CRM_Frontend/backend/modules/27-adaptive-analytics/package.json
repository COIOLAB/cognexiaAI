    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0",
    "python": ">=3.8.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "models/**/*",
    "*.md"
  ],
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/test/setup.ts"
    ],
    "testTimeout": 60000
  },
  "config": {
    "ml": {
      "autoTrain": true,
      "modelVersioning": true,
      "experimentTracking": true,
      "distributedTraining": true,
      "gpuAcceleration": true,
      "modelServing": true,
      "realTimeInference": true,
      "batchPrediction": true,
      "modelMonitoring": true,
      "dataValidation": true,
      "featureStore": true,
      "mlops": true
    },
    "analytics": {
      "realTimeProcessing": true,
      "batchProcessing": true,
      "streamProcessing": true,
      "adaptiveLearning": true,
      "continuousTraining": true,
      "onlineUpdates": true,
      "feedbackLoop": true
    }
  }
