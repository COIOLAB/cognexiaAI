{
  "name": "@industry5.0/digital-twin",
  "version": "1.0.0",
  "description": "Industry 5.0 Digital Twin - Quantum-Enhanced Real-Time Simulation & Modeling",
  "main": "dist/src/main.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate",
    "migration:run": "typeorm-ts-node-commonjs migration:run",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert",
    "seed": "ts-node src/database/seeds/seed.ts",
    "simulation:run": "ts-node src/tools/simulation-runner.ts",
    "models:sync": "ts-node src/tools/model-synchronizer.ts",
    "quantum:simulate": "python src/quantum-models/quantum-simulation.py"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/jwt": "^10.1.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/schedule": "^3.0.1",
    "@nestjs/event-emitter": "^2.0.0",
    "@nestjs/swagger": "^7.1.8",
    "@nestjs/bull": "^10.0.1",
    "@nestjs/websockets": "^10.0.0",
    "@nestjs/graphql": "^12.0.8",
    "@nestjs/apollo": "^12.0.7",
    "typeorm": "^0.3.17",
    "pg": "^8.11.3",
    "@supabase/supabase-js": "^2.38.0",
    "bull": "^4.11.3",
    "redis": "^4.6.8",
    "cache-manager": "^5.2.3",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "axios": "^1.5.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "uuid": "^9.0.0",
    "joi": "^17.9.2",
    "winston": "^3.10.0",
    "@tensorflow/tfjs-node": "^4.10.0",
    "@tensorflow/tfjs": "^4.10.0",
    "ml-matrix": "^6.10.4",
    "simple-statistics": "^7.8.3",
    "three": "^0.155.0",
    "cannon-es": "^0.20.0",
    "babylonjs": "^6.21.0",
    "@babylonjs/core": "^6.21.0",
    "@babylonjs/materials": "^6.21.0",
    "@babylonjs/loaders": "^6.21.0",
    "socket.io": "^4.7.2",
    "rxjs": "^7.8.1",
    "mathjs": "^11.11.0",
    "d3": "^7.8.5",
    "plotly.js": "^2.26.0",
    "opencv4nodejs": "^5.6.0",
    "reflect-metadata": "^0.1.13"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/three": "^0.155.1",
    "@types/d3": "^7.4.0",
    "jest": "^29.5.0",
    "typescript": "^5.1.3"
  },
  "keywords": ["digital-twin", "simulation", "3d", "quantum", "industry5.0"],
  "author": "Industry 5.0 Team",
  "license": "MIT"
}
