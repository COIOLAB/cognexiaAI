# Inventory Module - Environment Configuration Example
# Copy this file to .env and update with your actual values

# ================================
# STORAGE CONFIGURATION
# ================================

# Default Storage Provider
# Options: supabase, aws_s3, azure_blob, google_cloud, local_filesystem, minio, hybrid
DEFAULT_STORAGE_PROVIDER=supabase

# ================================
# SUPABASE STORAGE CONFIGURATION
# ================================

# Supabase Project URL (found in your Supabase dashboard)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Service Role Key (found in Settings > API)
# WARNING: Keep this secret! It has admin privileges
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Storage bucket name (will be created automatically if it doesn't exist)
SUPABASE_STORAGE_BUCKET=files

# Public URL for accessing files (constructed automatically based on SUPABASE_URL)
SUPABASE_PUBLIC_URL=https://your-project-id.supabase.co/storage/v1/object/public

# ================================
# LOCAL STORAGE CONFIGURATION
# ================================

# Local storage path (relative to application root)
LOCAL_STORAGE_PATH=./storage

# Public URL for serving local files (optional)
LOCAL_STORAGE_PUBLIC_URL=http://localhost:3000/files

# ================================
# AWS S3 CONFIGURATION (Alternative)
# ================================

# AWS S3 Bucket name
AWS_S3_BUCKET=your-s3-bucket-name

# AWS Access credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# AWS Region
AWS_REGION=us-east-1

# S3 endpoint (optional, for S3-compatible services)
AWS_S3_ENDPOINT=https://s3.amazonaws.com

# ================================
# AZURE BLOB STORAGE (Alternative)
# ================================

# Azure Storage Account name
AZURE_STORAGE_ACCOUNT=your_storage_account_name

# Azure Storage Account key or connection string
AZURE_STORAGE_KEY=your_storage_account_key

# Azure Blob container name
AZURE_BLOB_CONTAINER=files

# ================================
# GOOGLE CLOUD STORAGE (Alternative)
# ================================

# Google Cloud Project ID
GOOGLE_CLOUD_PROJECT_ID=your-project-id

# Google Cloud Storage bucket name
GOOGLE_CLOUD_STORAGE_BUCKET=your-bucket-name

# Path to service account key file
GOOGLE_CLOUD_KEY_FILE=./config/google-cloud-key.json

# ================================
# MINIO CONFIGURATION (Alternative)
# ================================

# MinIO endpoint
MINIO_ENDPOINT=localhost
MINIO_PORT=9000

# MinIO credentials
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key

# MinIO bucket name
MINIO_BUCKET=files

# Use SSL for MinIO connection
MINIO_USE_SSL=false

# ================================
# FILE MANAGEMENT SETTINGS
# ================================

# Maximum file size in bytes (default: 100MB)
MAX_FILE_SIZE=104857600

# Allowed file types (comma-separated MIME types)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain,application/json

# File upload timeout in milliseconds
FILE_UPLOAD_TIMEOUT=300000

# Enable file compression
ENABLE_FILE_COMPRESSION=true

# Enable file encryption at rest
ENABLE_FILE_ENCRYPTION=false

# File retention period in days (0 = never delete)
FILE_RETENTION_DAYS=365

# Enable file versioning
ENABLE_FILE_VERSIONING=true

# Maximum number of file versions to keep
MAX_FILE_VERSIONS=10

# ================================
# NOTIFICATION CONFIGURATION
# ================================

# SendGrid API key for email notifications
SENDGRID_API_KEY=your_sendgrid_api_key

# Twilio credentials for SMS notifications
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase credentials for push notifications
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Slack webhook URL for Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Microsoft Teams webhook URL
TEAMS_WEBHOOK_URL=https://your-tenant.webhook.office.com/webhookb2/...

# ================================
# SECURITY CONFIGURATION
# ================================

# Enable audit logging
ENABLE_AUDIT_LOGGING=true

# Enable file access logging
ENABLE_FILE_ACCESS_LOGGING=true

# Enable virus scanning (requires ClamAV or similar)
ENABLE_VIRUS_SCANNING=false

# Virus scanner API endpoint
VIRUS_SCANNER_ENDPOINT=http://localhost:3310

# Enable content type validation
ENABLE_CONTENT_TYPE_VALIDATION=true

# Enable file name sanitization
ENABLE_FILE_NAME_SANITIZATION=true

# ================================
# PERFORMANCE SETTINGS
# ================================

# Enable caching
ENABLE_CACHING=true

# Cache TTL in seconds (default: 1 hour)
CACHE_TTL=3600

# Enable compression for file transfers
ENABLE_COMPRESSION=true

# Number of concurrent file operations
MAX_CONCURRENT_OPERATIONS=10

# Connection pool size for storage providers
STORAGE_CONNECTION_POOL_SIZE=20

# ================================
# MONITORING & LOGGING
# ================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable structured logging (JSON format)
ENABLE_STRUCTURED_LOGGING=true

# Enable metrics collection
ENABLE_METRICS=true

# Metrics collection endpoint
METRICS_ENDPOINT=http://localhost:3001/metrics

# Enable health checks
ENABLE_HEALTH_CHECKS=true

# Health check interval in milliseconds
HEALTH_CHECK_INTERVAL=60000
