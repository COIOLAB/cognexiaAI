{
  "name": "@industry5.0/inventory-management",
  "version": "1.0.0",
  "description": "Advanced Industry 5.0 Inventory Management Module with AI, IoT, Quantum Computing, and Autonomous Operations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate",
    "migration:run": "typeorm-ts-node-commonjs migration:run",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert",
    "seed": "ts-node src/database/seeds/run-seeds.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "docker:build": "docker build -t inventory-management .",
    "docker:run": "docker run -p 3000:3000 inventory-management",
    "deploy:dev": "npm run build && npm run migration:run && npm start",
    "deploy:staging": "npm run build && npm run migration:run && npm run start:prod",
    "deploy:production": "npm run build && npm run migration:run && npm run start:prod"
  },
