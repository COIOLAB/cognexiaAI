    "yup": "^1.2.0",
    "zod": "^3.21.4",
    "sharp": "^0.32.4",
    "multer": "^1.4.5-lts.1",
    "file-type": "^18.5.0",
    "mime-types": "^2.1.35",
    "nanoid": "^4.0.2",
    "slugify": "^1.6.6",
    "validator": "^13.9.0",
    "sanitize-html": "^2.11.0",
    "dompurify": "^3.0.3",
    "jsdom": "^22.1.0",
    "cheerio": "^1.0.0-rc.12",
    "fast-csv": "^4.3.6",
    "xlsx": "^0.18.5",
