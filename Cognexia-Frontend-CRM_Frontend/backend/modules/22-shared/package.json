{
  "name": "@ezai-mfg-ninja/shared",
  "version": "1.0.0",
  "description": "Industry 5.0 ERP Shared Components and Services - Core utilities, services, types, decorators, guards, interceptors, and common functionality for all manufacturing modules",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./services/*": {
      "import": "./dist/src/services/*.js",
      "require": "./dist/src/services/*.js",
      "types": "./dist/src/services/*.d.ts"
    },
    "./utils/*": {
      "import": "./dist/src/utils/*.js",
      "require": "./dist/src/utils/*.js",
      "types": "./dist/src/utils/*.d.ts"
    },
    "./types/*": {
      "import": "./dist/src/types/*.js",
      "require": "./dist/src/types/*.js",
      "types": "./dist/src/types/*.d.ts"
    },
    "./decorators/*": {
      "import": "./dist/src/decorators/*.js",
      "require": "./dist/src/decorators/*.js",
      "types": "./dist/src/decorators/*.d.ts"
    },
    "./guards/*": {
      "import": "./dist/src/guards/*.js",
      "require": "./dist/src/guards/*.js",
      "types": "./dist/src/guards/*.d.ts"
    },
    "./interceptors/*": {
      "import": "./dist/src/interceptors/*.js",
      "require": "./dist/src/interceptors/*.js",
      "types": "./dist/src/interceptors/*.d.ts"
    },
    "./middleware/*": {
      "import": "./dist/src/middleware/*.js",
      "require": "./dist/src/middleware/*.js",
      "types": "./dist/src/middleware/*.d.ts"
    },
    "./pipes/*": {
      "import": "./dist/src/pipes/*.js",
      "require": "./dist/src/pipes/*.js",
      "types": "./dist/src/pipes/*.d.ts"
    },
    "./filters/*": {
      "import": "./dist/src/filters/*.js",
      "require": "./dist/src/filters/*.js",
      "types": "./dist/src/filters/*.d.ts"
    },
    "./constants/*": {
      "import": "./dist/src/constants/*.js",
      "require": "./dist/src/constants/*.js",
      "types": "./dist/src/constants/*.d.ts"
    },
    "./enums/*": {
      "import": "./dist/src/enums/*.js",
      "require": "./dist/src/enums/*.js",
      "types": "./dist/src/enums/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "postbuild": "npm run copy:assets",
    "copy:assets": "copyfiles -u 1 src/**/*.json src/**/*.yaml src/**/*.yml dist/",
    "start:dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r ts-node/register -r tsconfig-paths/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "precommit": "lint-staged"
  },
  "keywords": [
    "shared",
    "common",
    "utilities",
    "services",
    "types",
    "decorators",
    "guards",
    "interceptors",
    "middleware",
    "pipes",
    "filters",
    "constants",
    "enums",
    "core",
    "foundation",
    "industry-5.0",
    "manufacturing",
    "erp",
    "nestjs",
    "typescript"
  ],
  "author": {
    "name": "EzAi MfgNinja Team",
    "email": "shared@ezai-mfgninja.com",
    "url": "https://ezai-mfgninja.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ezai-mfg-ninja/industry5.0-shared.git"
  },
  "bugs": {
    "url": "https://github.com/ezai-mfg-ninja/industry5.0-shared/issues"
  },
  "homepage": "https://github.com/ezai-mfg-ninja/industry5.0-shared#readme",
  "dependencies": {
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
