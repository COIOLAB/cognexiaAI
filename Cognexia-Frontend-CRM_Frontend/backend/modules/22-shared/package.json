    "dayjs": "^1.11.9",
    "luxon": "^3.3.0",
    "cron": "^2.4.0",
    "node-cron": "^3.0.2",
    "bull": "^4.11.0",
    "ioredis": "^5.3.2",
    "cache-manager": "^5.2.3",
    "cache-manager-redis-store": "^3.0.1",
    "node-cache": "^5.1.2",
    "lru-cache": "^10.0.0",
    "eventemitter3": "^5.0.1",
    "mitt": "^3.0.1",
    "socket.io": "^4.7.2",
    "ws": "^8.13.0",
    "sse-js": "^0.6.1",
    "node-fetch": "^3.3.1",
    "axios": "^1.5.0",
    "got": "^13.0.0",
    "superagent": "^8.1.0",
    "form-data": "^4.0.0",
    "qs": "^6.11.2",
    "chalk": "^5.3.0",
    "colors": "^1.4.0",
    "figlet": "^1.7.0",
    "ora": "^7.0.1",
    "inquirer": "^9.2.8",
    "commander": "^11.0.0",
    "yargs": "^17.7.2",
    "dotenv": "^16.3.1",
    "config": "^3.3.9",
    "node-config-ts": "^4.0.0",
    "convict": "^6.2.4",
    "cross-env": "^7.0.3",
    "glob": "^10.3.3",
    "minimatch": "^9.0.3",
    "chokidar": "^3.5.3",
    "nodemon": "^3.0.1",
    "pm2": "^5.3.0",
    "cluster": "^0.7.7",
    "os-utils": "^0.0.14",
    "systeminformation": "^5.21.7",
    "pidusage": "^3.0.2"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.195",
    "@types/uuid": "^9.0.2",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/compression": "^1.7.2",
    "@types/multer": "^1.4.7",
    "@types/mime-types": "^2.1.1",
    "@types/validator": "^13.7.17",
    "@types/sanitize-html": "^2.9.0",
    "@types/dompurify": "^3.0.2",
    "@types/jsdom": "^21.1.1",
    "@types/qrcode": "^1.5.1",
    "@types/pdfkit": "^0.12.9",
    "@types/node-cron": "^3.0.8",
    "@types/ws": "^8.5.5",
    "@types/node-fetch": "^2.6.4",
    "@types/qs": "^6.9.7",
    "@types/inquirer": "^9.0.3",
    "@types/yargs": "^17.0.24",
    "@types/config": "^3.3.0",
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "prettier": "^2.8.8",
    "typescript": "^5.1.3",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "rimraf": "^5.0.1",
    "copyfiles": "^2.4.1",
    "lint-staged": "^13.2.3",
    "husky": "^8.0.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/event-emitter": "^2.0.0",
    "@nestjs/bull": "^10.0.0",
    "@nestjs/cache-manager": "^2.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/schedule": "^3.0.0",
    "@nestjs/microservices": "^10.0.0",
    "@nestjs/websockets": "^10.0.0",
    "@nestjs/graphql": "^12.0.0",
    "typeorm": "^0.3.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "*.md"
  ],
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "config": {
    "shared": {
      "utilities": true,
      "services": true,
      "types": true,
      "decorators": true,
      "guards": true,
      "interceptors": true,
      "middleware": true,
      "pipes": true,
      "filters": true,
      "constants": true,
      "enums": true,
      "validators": true,
      "transformers": true,
      "exceptions": true,
      "logging": true,
      "caching": true,
      "events": true,
      "queues": true,
      "security": true,
      "performance": true,
      "monitoring": true
    }
  }
}
