    "scheduler:start": "ts-node scripts/start-scheduler.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "precommit": "lint-staged",
    "serve:ui": "ts-node scripts/serve-orchestration-ui.ts",
    "serve:dashboard": "ts-node scripts/serve-dashboard.ts"
