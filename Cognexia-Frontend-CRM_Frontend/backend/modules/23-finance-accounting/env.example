# Industry 5.0 Finance & Accounting Module - Environment Configuration
# Copy this file to .env and configure your settings

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
NODE_ENV=development
PORT=3000
FINANCE_DEBUG=true

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_NAME=industry50_finance
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_SSL=false

# Database Connection Pooling
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_ACQUIRE_TIMEOUT=60000
DB_CREATE_TIMEOUT=30000
DB_DESTROY_TIMEOUT=5000
DB_IDLE_TIMEOUT=30000
DB_REAP_INTERVAL=1000
DB_CREATE_RETRY_INTERVAL=200

# Database Replicas (Optional)
DB_MASTER_HOST=localhost
DB_MASTER_PORT=5432
DB_SLAVE_HOST=localhost
DB_SLAVE_PORT=5433

# Migration Settings
DB_RUN_MIGRATIONS=false

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# Cache Settings
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000
CACHE_DURATION=30000

# ============================================================================
# BUSINESS RULES
# ============================================================================

# Currency Settings
BASE_CURRENCY=USD
SUPPORTED_CURRENCIES=USD,EUR,GBP,JPY,CNY,CAD,AUD
FX_PROVIDER=xe.com

# Financial Periods
FISCAL_YEAR_START=01-01
REPORTING_FREQUENCY=monthly

# Approval Thresholds
INVOICE_APPROVAL_THRESHOLD=10000
PAYMENT_APPROVAL_THRESHOLD=5000
BUDGET_APPROVAL_THRESHOLD=50000

# Validation Limits
MAX_INVOICE_AMOUNT=1000000
MAX_PAYMENT_AMOUNT=500000
DUPLICATE_CHECK_WINDOW=30

# ============================================================================
# ACCOUNTING STANDARDS
# ============================================================================
ACCOUNTING_STANDARD=GAAP
SECONDARY_STANDARD=IFRS
JURISDICTION=US
TAX_REGION=US

# ============================================================================
# COMPLIANCE SETTINGS
# ============================================================================
SOX_COMPLIANCE=false
GDPR_COMPLIANCE=true
PCI_DSS_COMPLIANCE=false
AUDIT_RETENTION_DAYS=2555
DATA_ENCRYPTION=true

# ============================================================================
# AI & ANALYTICS
# ============================================================================
AI_ENABLED=true
AI_PROVIDER=openai
AI_CONFIDENCE_THRESHOLD=0.8
FRAUD_DETECTION=true
ANOMALY_DETECTION=true
PREDICTIVE_ANALYTICS=true

# OpenAI Configuration (if using OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=4000

# ============================================================================
# INTEGRATIONS
# ============================================================================

# Banking Integration
BANKING_INTEGRATION=false
BANKING_PROVIDERS=yodlee,plaid
BANKING_REFRESH_INTERVAL=3600

# Payment Gateways
PAYMENT_PROVIDERS=stripe,paypal,square
PAYMENT_WEBHOOK_SECRET=your_webhook_secret_here
PAYMENT_RETRY_ATTEMPTS=3

# Tax Services
TAX_PROVIDER=avalara
AUTO_TAX_CALC=true
NEXUS_STATES=CA,NY,TX

# ERP Integration
CRM_INTEGRATION=true
SCM_INTEGRATION=true
HR_INTEGRATION=true
MFG_INTEGRATION=true

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# Encryption
ENCRYPTION_ALGORITHM=aes-256-gcm
KEY_ROTATION_DAYS=90

# Access Control
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION=900
SESSION_TIMEOUT=3600

# Audit
LOG_ALL_TRANSACTIONS=true
AUDIT_RETENTION=2555
REALTIME_AUDIT=true

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=3600

# ============================================================================
# PERFORMANCE SETTINGS
# ============================================================================

# Batch Processing
BATCH_SIZE=1000
PARALLEL_PROCESSING=true
MAX_CONCURRENCY=10

# Reporting
ASYNC_REPORTS=true
REPORT_CACHE=true
BG_GENERATION=true

# ============================================================================
# NOTIFICATION SETTINGS
# ============================================================================

# Email
EMAIL_NOTIFICATIONS=true
EMAIL_PROVIDER=sendgrid
FROM_EMAIL=finance@company.com
SENDGRID_API_KEY=your_sendgrid_api_key_here
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key_here

# SMS
SMS_NOTIFICATIONS=false
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here

# Webhooks
WEBHOOK_NOTIFICATIONS=false
WEBHOOK_ENDPOINTS=https://your-webhook-endpoint.com/finance

# ============================================================================
# BACKUP & RECOVERY
# ============================================================================
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION=true
OFFSITE_BACKUP=false

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs/finance.log
LOG_ROTATION=daily

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health

# ============================================================================
# EXTERNAL API KEYS (Add your actual keys)
# ============================================================================

# Banking APIs
YODLEE_API_KEY=your_yodlee_key_here
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here

# Payment Processors
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# Tax Services
AVALARA_ACCOUNT_ID=your_avalara_account_id_here
AVALARA_LICENSE_KEY=your_avalara_license_key_here
