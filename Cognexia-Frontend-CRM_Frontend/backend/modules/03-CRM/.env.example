# =============================================================================
# CognexiaAI CRM - COMPLETE ENVIRONMENT CONFIGURATION
# =============================================================================
# This is a COMPOSITE of all environment variables for LOCAL and PRODUCTION.
# Copy to .env for local dev. For Railway: add each variable in Dashboard → Variables
# NEVER commit .env with real secrets to git!
# =============================================================================

# =============================================================================
# CORE APPLICATION
# =============================================================================
NODE_ENV=production
PORT=3003
APP_NAME=CognexiaAI-CRM
APP_VERSION=1.0.0
APP_HOST=0.0.0.0

# =============================================================================
# DATABASE - Choose ONE option
# =============================================================================

# --- OPTION 1: RAILWAY POSTGRES (production - recommended) ---
# In Railway: Add Postgres service → CRM Backend Variables → Add Reference → DATABASE_URL
# Do not set DATABASE_HOST/PORT/USER/PASSWORD/NAME when using DATABASE_URL
# DATABASE_URL=<set via Railway Variable Reference from Postgres service>

# --- OPTION 2: LOCAL POSTGRESQL (development) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=Akshita@19822
DATABASE_NAME=cognexia_crm

# --- OPTION 3: SUPABASE (optional; prefer Railway Postgres for deployment) ---
# DATABASE_HOST=db.moijigidcrvbnjoaqelr.supabase.co
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=YOUR_SUPABASE_PASSWORD
# DATABASE_NAME=postgres
# Or: DATABASE_URL=postgresql://postgres:PASSWORD@db.XXX.supabase.co:5432/postgres?sslmode=require

# Connection pool settings
DATABASE_POOL_MIN=10
DATABASE_POOL_MAX=100
DATABASE_IDLE_TIMEOUT=30000
DATABASE_CONNECTION_TIMEOUT=60000

