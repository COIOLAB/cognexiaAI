# AI Configuration
AI_MODEL_VERSION=v1.0.0
AI_INFERENCE_TIMEOUT=30000
AI_PROCESSING_TIMEOUT=300000

# =============================================================================
# STRIPE PAYMENTS
# Get from: https://dashboard.stripe.com/apikeys
# =============================================================================
# STRIPE_SECRET_KEY=sk_live_YOUR_KEY
# STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

# =============================================================================
# REDIS CACHE (Optional)
# =============================================================================
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL=3600

# =============================================================================
# FEATURE FLAGS
# =============================================================================
DEMO_ENABLED=true
ENABLE_SWAGGER=true
SWAGGER_ENABLED=true
DEBUG_MODE=false

# Security features
RBAC_ENABLED=true
SECURITY_AUDIT_ENABLED=true
MFA_ENABLED=true
SSO_ENABLED=false

# Advanced features
COLLABORATION_ENABLED=true
ANALYTICS_ENABLED=true
WORKFLOW_AUTOMATION_ENABLED=true
HOLOGRAPHIC_SERVICES_ENABLED=true
QUANTUM_INTELLIGENCE_ENABLED=true
PREDICTIVE_ANALYTICS_ENABLED=true
TENSORFLOW_ENABLED=true
NLP_ENABLED=true
SENTIMENT_ANALYSIS_ENABLED=true

# =============================================================================
# APP URLS (for emails, links)
# =============================================================================
APP_URL=http://localhost:3002
FRONTEND_URL=http://localhost:3002
SUPER_ADMIN_EMAIL=superadmin@cognexiaai.com

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_VERSION=v1
API_PREFIX=/api/v1
API_RATE_LIMIT=1000
API_RATE_LIMIT_WINDOW=60000

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_ENABLED=true
LOG_PATH=./logs
LOG_TO_FILE=true

# =============================================================================
# STORAGE
# =============================================================================
STORAGE_PROVIDER=supabase
STORAGE_BUCKET=crm-documents
STORAGE_PUBLIC_BUCKET=crm-avatars
MAX_FILE_SIZE=10485760
CLOUD_STORAGE_ENABLED=true
CLOUD_STORAGE_PROVIDER=supabase

# =============================================================================
# ALTERNATE SMS PROVIDERS (Optional)
# =============================================================================
# VONAGE_API_KEY=
# VONAGE_API_SECRET=
# VONAGE_SMS_FROM=CognexiaAI
# VONAGE_APPLICATION_ID=
# MESSAGEBIRD_ACCESS_KEY=
# MESSAGEBIRD_SMS_ORIGINATOR=CognexiaAI

# =============================================================================
# ENTERPRISE SECURITY (Production)
# =============================================================================
COMPLIANCE_MODE=strict
ENCRYPTION_KEY=change-this-to-256-bit-key
SECURITY_FRAMEWORK_ENABLED=true
MULTI_FACTOR_AUTH_ENABLED=true

# Password policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# Session
SESSION_TIMEOUT=30m
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=15m

# =============================================================================
# COMPLIANCE (Optional enterprise features)
# =============================================================================
GDPR_COMPLIANCE_ENABLED=true
SOX_COMPLIANCE_ENABLED=false
HIPAA_COMPLIANCE_ENABLED=false
ISO27001_COMPLIANCE_ENABLED=true

# Data retention
DATA_RETENTION_PERIOD_DAYS=2555
AUDIT_LOG_RETENTION_DAYS=2555

# =============================================================================
# HEALTH & MONITORING
# =============================================================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000
PERFORMANCE_MONITORING_ENABLED=true

# =============================================================================
# BRANDING
# =============================================================================
COMPANY_NAME=CognexiaAI
COMPANY_DOMAIN=cognexiaai.com
BRAND_PRIMARY_COLOR=#1E40AF
BRAND_SECONDARY_COLOR=#06B6D4

# =============================================================================
# DEPLOYMENT (Auto-set by Railway/CI)
# =============================================================================
# DEPLOYMENT_VERSION=1.0.0
# DEPLOYMENT_ENVIRONMENT=production
# BUILD_NUMBER=001
# GIT_COMMIT_HASH=
# DEPLOYMENT_REGION=us-east-1
