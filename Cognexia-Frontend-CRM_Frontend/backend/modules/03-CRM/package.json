{
  "name": "industry5.0-crm",
  "version": "1.0.0",
  "description": "Industry 5.0 CRM Module - Advanced customer relationship management with AI, quantum intelligence, holographic experiences, and enterprise security",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start:prod": "node dist/main.js",
    "start:debug": "ts-node-dev --inspect --respawn --transpile-only src/main.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/migration-data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/migration-data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/migration-data-source.ts",
    "seed": "ts-node src/database/seeds/seed.ts",
    "seed-db": "ts-node seed-database.ts",
    "create-test-org": "ts-node create-test-org.ts",
    "seed-test-data": "ts-node seed-test-data.ts",
    "seed-admin-user": "ts-node seed-admin-user.ts",
    "seed-api-fixtures": "ts-node seed-api-fixtures.ts",
    "db:migrate": "npm run migration:run",
    "db:seed": "npm run seed",
    "db:reset": "npm run migration:revert && npm run migration:run && npm run seed",
    "health": "curl -f http://localhost:3000/health || exit 1",
    "docker:build": "docker build -t industry5.0-crm:latest .",
    "docker:run": "docker run -p 3000:3000 industry5.0-crm:latest",
    "validate": "npm run lint && npm run test && npm run build",
    "security:audit": "npm audit --audit-level moderate",
    "docs": "typedoc --out docs src",
    "clean": "rm -rf dist coverage docs",
    "prepare": "npm run build",
    "prestart:prod": "npm run build"
  },
  "dependencies": {
    "@babylonjs/core": "^6.49.0",
    "@nestjs/cache-manager": "^2.1.1",
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.20",
    "@nestjs/event-emitter": "^2.1.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/serve-static": "^4.0.0",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/throttler": "^5.0.1",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.22",
    "@supabase/supabase-js": "^2.55.0",
    "@tensorflow/tfjs": "^4.22.0",
