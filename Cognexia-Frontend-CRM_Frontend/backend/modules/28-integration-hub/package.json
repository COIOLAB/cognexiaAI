{
  "name": "@ezai-mfg-ninja/integration-hub",
  "version": "1.0.0",
  "description": "Industry 5.0 Integration Hub Module - Universal integration platform for seamless connectivity between all manufacturing systems, protocols, and third-party services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/index.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start:debug": "node --inspect-brk -r ts-node/register src/index.ts",
    "start:prod": "node dist/index.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsnode/register -r tsconfig-paths/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration": "jest --config ./test/jest-integration.json",
    "protocol:test": "ts-node scripts/test-protocols.ts",
    "connector:validate": "ts-node scripts/validate-connectors.ts",
    "mapping:generate": "ts-node scripts/generate-mappings.ts",
    "schema:sync": "ts-node scripts/sync-schemas.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "precommit": "lint-staged",
    "serve:docs": "redoc-cli serve docs/api.yaml",
    "serve:dashboard": "ts-node scripts/serve-dashboard.ts"
  },
  "keywords": [
    "integration-hub",
    "system-integration",
    "protocol-gateway",
    "data-transformation",
    "message-routing",
    "api-gateway",
    "middleware",
    "connector-framework",
    "enterprise-integration",
    "etl",
    "data-pipeline",
    "real-time-sync",
    "batch-processing",
    "stream-processing",
    "webhook-handler",
    "event-driven",
    "microservices",
    "industry-5.0",
    "manufacturing-integration",
    "nestjs",
    "typescript"
  ],
  "author": {
