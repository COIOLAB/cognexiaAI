  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "schemas/**/*",
    "connectors/**/*",
    "*.md"
  ],
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/test/setup.ts"
    ],
    "testTimeout": 30000
  },
  "config": {
    "integration": {
      "protocols": [
        "http",
        "https",
        "grpc",
        "graphql",
        "websocket",
        "mqtt",
        "amqp",
        "kafka",
        "nats",
        "redis",
        "tcp",
        "udp"
      ],
      "formats": [
        "json",
        "xml",
        "yaml",
        "csv",
        "avro",
        "protobuf",
        "msgpack",
        "cbor",
        "bson"
      ],
      "connectors": {
        "enterprise": true,
        "cloud": true,
        "iot": true,
        "legacy": true,
        "custom": true
      },
      "transformation": {
        "realTime": true,
        "batch": true,
        "stream": true,
        "etl": true,
        "dataMapping": true,
        "schemaEvolution": true
      }
    }
  }
