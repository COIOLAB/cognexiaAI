    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^3.0.9",
    "@types/bcryptjs": "^2.4.2",
    "@types/lodash": "^4.14.195",
    "@types/uuid": "^9.0.2",
    "@types/compression": "^1.7.2",
    "@types/node-forge": "^1.3.4",
    "@types/libsodium-wrappers": "^0.7.10",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.5.0",
    "prettier": "^2.8.8",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "webpack": "^5.88.0",
    "lint-staged": "^13.2.3",
    "husky": "^8.0.3",
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "source-map-support": "^0.5.21"
  },
  "peerDependencies": {
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "*.md"
  ],
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/test/setup.ts"
    ]
  },
  "config": {
    "quantum": {
      "algorithms": [
        "kyber",
        "dilithium",
        "falcon",
        "sphincs-plus",
        "ntru",
        "frodo-kem",
        "classic-mceliece",
        "rainbow",
        "sike"
      ],
      "keySize": 4096,
      "securityLevel": 5,
      "quantumResistant": true,
      "nistCompliant": true
    }
  }
}
