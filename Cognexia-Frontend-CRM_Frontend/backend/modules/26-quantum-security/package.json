{
  "name": "@ezai-mfg-ninja/quantum-security",
  "version": "1.0.0",
  "description": "Industry 5.0 Quantum Security Module - Advanced quantum cryptography, post-quantum encryption, and quantum-resistant security protocols for next-generation manufacturing systems",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/index.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start:debug": "node --inspect-brk -r ts-node/register src/index.ts",
    "start:prod": "node dist/index.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsnode/register -r tsconfig-paths/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:quantum": "jest --config ./test/jest-quantum.json",
    "quantum:keygen": "ts-node scripts/quantum-keygen.ts",
    "quantum:benchmark": "ts-node scripts/quantum-benchmark.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "precommit": "lint-staged"
  },
  "keywords": [
    "quantum-security",
    "quantum-cryptography",
    "post-quantum",
    "quantum-resistant",
    "qkd",
    "quantum-key-distribution",
    "lattice-cryptography",
    "kyber",
    "dilithium",
    "industry-5.0",
    "manufacturing-security",
    "nestjs",
    "typescript"
  ],
  "author": {
    "name": "EzAi MfgNinja Team",
    "email": "quantum-security@ezai-mfgninja.com",
    "url": "https://ezai-mfgninja.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ezai-mfg-ninja/industry5.0-quantum-security.git"
  },
  "bugs": {
    "url": "https://github.com/ezai-mfg-ninja/industry5.0-quantum-security/issues"
  },
  "homepage": "https://github.com/ezai-mfg-ninja/industry5.0-quantum-security#readme",
  "dependencies": {
