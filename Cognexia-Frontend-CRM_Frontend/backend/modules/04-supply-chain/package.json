{
  "name": "industry5.0-supply-chain",
  "version": "1.0.0",
  "description": "Industry 5.0 Supply Chain Module - Advanced supply chain management with AI intelligence, blockchain tracking, quantum optimization, IoT integration, and autonomous networks",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start:prod": "node dist/index.js",
    "start:debug": "ts-node-dev --inspect --respawn --transpile-only src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",
    "seed": "ts-node src/database/seeds/seed.ts",
    "db:migrate": "npm run migration:run",
    "db:seed": "npm run seed",
    "db:reset": "npm run migration:revert && npm run migration:run && npm run seed",
    "health": "curl -f http://localhost:3000/health || exit 1",
    "docker:build": "docker build -t industry5.0-supply-chain:latest .",
    "docker:run": "docker run -p 3000:3000 industry5.0-supply-chain:latest",
    "validate": "npm run lint && npm run test && npm run build",
    "security:audit": "npm audit --audit-level moderate",
    "docs": "typedoc --out docs src",
    "clean": "rm -rf dist coverage docs",
    "prepare": "npm run build",
    "prestart:prod": "npm run build",
    "blockchain:deploy": "ts-node scripts/deploy-contracts.ts",
    "quantum:optimize": "ts-node scripts/quantum-optimization.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
