    "@nestjs/serve-static": "^4.0.0",
    "@nestjs/cache-manager": "^2.1.1",
    
    "typeorm": "^0.3.17",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    
    "passport": "^0.6.0",
