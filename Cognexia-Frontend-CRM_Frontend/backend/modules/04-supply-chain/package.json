    "express-openapi-validator": "^5.1.4",
    
    "zod": "^3.22.4",
    "ajv": "^8.12.0",
    "celebrate": "^15.0.3",
    
    "pino": "^8.16.2",
    "pino-pretty": "^10.2.3",
    "elastic-apm-node": "^4.0.0",
    
    "serialport": "^12.0.0",
    "node-opcua": "^2.117.0",
