# EzAi-MFGNINJA Cloud Production Environment Template
# Copy this to .env.cloud and fill in your actual values
# Generated for Supabase + MongoDB Cloud Deployment

# ==================== SUPABASE CONFIGURATION ====================
# Get these from your Supabase project dashboard
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==================== MONGODB CONFIGURATION ====================
# MongoDB Atlas or your MongoDB cloud service
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ezai_mfgninja?retryWrites=true&w=majority

# ==================== SECURITY KEYS ====================
# Generate secure random keys for production
JWT_SECRET=your-256-bit-jwt-secret-key-here
JWT_REFRESH_SECRET=your-256-bit-refresh-secret-key-here
ENCRYPTION_KEY=your-256-bit-encryption-key-here

# ==================== MONITORING & ANALYTICS ====================
GRAFANA_PASSWORD=secure-grafana-admin-password
GRAFANA_SECRET_KEY=secure-grafana-secret-key

# ==================== APPLICATION CONFIGURATION ====================
NODE_ENV=production
APP_NAME=EzAi-MFGNINJA
APP_VERSION=3.0.0

# ==================== COMPLIANCE & SECURITY ====================
GOVERNMENT_CERTIFICATION=enabled
AUDIT_ENABLED=true
ENCRYPTION_ENABLED=true
LOG_LEVEL=info

# ==================== CORS & API CONFIGURATION ====================
ALLOWED_ORIGINS=https://localhost:3000,https://your-domain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ==================== OPTIONAL INTEGRATIONS ====================
# Add any additional cloud service configurations here
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# SENDGRID_API_KEY=your-sendgrid-key
# STRIPE_SECRET_KEY=your-stripe-key
