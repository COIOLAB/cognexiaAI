# ==================== APPLICATION ENVIRONMENT ====================
NODE_ENV=production
GOVERNMENT_CERTIFICATION=enabled
SECURITY_LEVEL=maximum
COMPLIANCE_LEVEL=full
AUDIT_ENABLED=true
ENCRYPTION_ENABLED=true

# ==================== SUPABASE CONFIGURATION ====================
# Replace with your actual Supabase project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Replace with your Supabase anonymous key
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# Replace with your Supabase service role key (KEEP SECRET!)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-key

# ==================== DATABASE CONFIGURATION ====================
# MongoDB Connection String (Use MongoDB Atlas or secure self-hosted)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ezai_mfgninja_gov?retryWrites=true&w=majority

# ==================== JWT & ENCRYPTION SECRETS ====================
# SECURITY: Generate strong, unique secrets for production!
# Use: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-256bit-minimum
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-256bit-minimum

# AES-256 Encryption Key for sensitive data
# Use: openssl rand -base64 32
ENCRYPTION_KEY=your-aes-256-encryption-key-change-this-32-bytes-minimum

# ==================== MONITORING & ANALYTICS ====================
# Grafana Admin Credentials
GRAFANA_ADMIN_USER=ezai_admin
GRAFANA_ADMIN_PASSWORD=EzAi_Grafana_Gov_2025!_SecurePassword

# Grafana Secret Key for signing cookies
GRAFANA_SECRET_KEY=ezai_grafana_secret_gov_2025_change_this_key

# ElasticSearch Password
ELASTIC_PASSWORD=EzAi_Elastic_Gov_2025!_SecurePassword

# Redis Password
REDIS_PASSWORD=EzAi_Redis_Gov_2025!_SecurePassword

# ==================== API KEYS & INTEGRATIONS ====================
# OpenAI API Key for AI features
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google Cloud API Key for additional services
GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key

# Azure OpenAI Configuration (Alternative to OpenAI)
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# ==================== EMAIL & NOTIFICATIONS ====================
# SMTP Configuration for notifications
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
FROM_EMAIL=noreply@yourdomain.com

# ==================== BLOCKCHAIN & QUANTUM CONFIGS ====================
# Blockchain Network Configuration
BLOCKCHAIN_NETWORK=ethereum-mainnet
BLOCKCHAIN_PRIVATE_KEY=your-blockchain-private-key-keep-secret

# Quantum Computing API Configuration
QUANTUM_API_ENDPOINT=https://api.quantum-provider.com
QUANTUM_API_KEY=your-quantum-api-key

# ==================== COMPLIANCE & AUDIT ====================
# Audit Log Configuration
AUDIT_LOG_RETENTION_DAYS=2557  # 7 years for financial compliance
AUDIT_LOG_ENCRYPTION=true
AUDIT_LOG_REMOTE_BACKUP=true

# SOX Compliance Settings
SOX_COMPLIANCE=enabled
SOX_AUDIT_TRAIL=enabled
SOX_DATA_RETENTION=2557  # 7 years

# GDPR Compliance Settings
GDPR_COMPLIANCE=enabled
GDPR_DATA_ANONYMIZATION=enabled
GDPR_RIGHT_TO_DELETE=enabled

# FedRAMP Settings
FEDRAMP_COMPLIANCE=enabled
FEDRAMP_CONTINUOUS_MONITORING=enabled

# ==================== SECURITY CONFIGURATIONS ====================
# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_TIMEOUT_MINUTES=30
FORCE_HTTPS=true
SECURE_COOKIES=true

# Multi-Factor Authentication
MFA_ENABLED=true
MFA_TOKEN_EXPIRY_MINUTES=5

# Password Policy
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_SPECIAL_CHARS=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true

# ==================== LOGGING & MONITORING ====================
# Log Levels (error, warn, info, debug)
LOG_LEVEL=info
LOG_FORMAT=json
LOG_REMOTE_ENDPOINT=https://your-log-aggregator.com

# Prometheus Metrics
METRICS_ENABLED=true
METRICS_ENDPOINT=/metrics

# Health Check Configuration
HEALTH_CHECK_TIMEOUT_MS=5000
HEALTH_CHECK_INTERVAL_MS=30000

# ==================== BACKUP & DISASTER RECOVERY ====================
# Database Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=90
BACKUP_ENCRYPTION_ENABLED=true

# Disaster Recovery
DR_ENABLED=true
DR_FAILOVER_ENDPOINT=https://dr.yourdomain.com
DR_RPO_MINUTES=60  # Recovery Point Objective
DR_RTO_MINUTES=240  # Recovery Time Objective

# ==================== IOT & DEVICE INTEGRATION ====================
# IoT Device Authentication
IOT_DEVICE_CERTIFICATES_PATH=/etc/ssl/iot-devices/
IOT_MQTT_BROKER=mqtt://your-mqtt-broker:8883
IOT_MQTT_USERNAME=iot-user
IOT_MQTT_PASSWORD=iot-secure-password

# Edge Computing Configuration
EDGE_COMPUTING_ENABLED=true
EDGE_NODES_CONFIG=/config/edge-nodes.json

# ==================== AI & MACHINE LEARNING ====================
# TensorFlow Serving Configuration
TENSORFLOW_SERVING_HOST=tensorflow-serving
TENSORFLOW_SERVING_PORT=8501

# Model Storage Configuration
MODEL_STORAGE_BUCKET=s3://your-ml-models-bucket
MODEL_VERSION_TRACKING=enabled

# ==================== DEVELOPMENT & DEBUGGING ====================
# Only enable in development environments
DEBUG_MODE=false
VERBOSE_LOGGING=false
API_DOCUMENTATION_ENABLED=false

# ==================== THIRD-PARTY INTEGRATIONS ====================
# ERP Systems Integration
SAP_API_ENDPOINT=https://your-sap-system.com/api
SAP_API_KEY=your-sap-api-key

# CRM Integration
SALESFORCE_API_ENDPOINT=https://your-instance.salesforce.com
SALESFORCE_API_KEY=your-salesforce-api-key

# Financial Systems
QUICKBOOKS_API_ENDPOINT=https://api.quickbooks.com
QUICKBOOKS_API_KEY=your-quickbooks-api-key

