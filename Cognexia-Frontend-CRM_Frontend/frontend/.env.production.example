# =============================================================================
# CognexiaAI ERP - Single Production .env for Vercel
# =============================================================================
# Use this as the single reference for ALL frontend portals (auth-portal,
# client-admin-portal, super-admin-portal). In Vercel, add these in each
# project's Settings → Environment Variables (Production).
# Replace placeholders with your real URLs and values.
# =============================================================================

# -----------------------------------------------------------------------------
# ALL PORTALS (required for every Vercel project)
# -----------------------------------------------------------------------------

# Backend CRM API base URL (Railway) - include /api/v1
NEXT_PUBLIC_API_URL=https://crm-backend-production-03da.up.railway.app/api/v1

# -----------------------------------------------------------------------------
# AUTH PORTAL (auth-portal) - Marketing + Login
# -----------------------------------------------------------------------------

# Portal URLs - where users are redirected after login
NEXT_PUBLIC_SUPER_ADMIN_PORTAL_URL=https://super-admin.your-app.vercel.app
NEXT_PUBLIC_CLIENT_ADMIN_PORTAL_URL=https://client-admin.your-app.vercel.app
NEXT_PUBLIC_CLIENT_PORTAL_URL=https://client-admin.your-app.vercel.app

# Optional: Super Admin quick-login (avoid hardcoding in code)
# NEXT_PUBLIC_SUPER_ADMIN_EMAIL=superadmin@cognexiaai.com
# NEXT_PUBLIC_SUPER_ADMIN_PASSWORD=
# NEXT_PUBLIC_SUPER_ADMIN_MOBILE=+1xxx
# NEXT_PUBLIC_TOTP_SECRET=

# Optional: Supabase (only if auth-portal uses careers/contact forms)
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# CLIENT ADMIN PORTAL (client-admin-portal)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_APP_NAME=CognexiaAI ERP
NEXT_PUBLIC_APP_URL=https://client-admin.your-app.vercel.app

# When a super-admin logs in here, redirect to super-admin portal
NEXT_PUBLIC_SUPER_ADMIN_PORTAL_URL=https://super-admin.your-app.vercel.app

# WebSocket (optional - for real-time/telephony)
NEXT_PUBLIC_WS_URL=wss://crm-backend-production-03da.up.railway.app

# Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_REAL_TIME=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_WEBHOOKS=false
NEXT_PUBLIC_ENABLE_BILLING=false

# -----------------------------------------------------------------------------
# SUPER ADMIN PORTAL (super-admin-portal)
# -----------------------------------------------------------------------------

# For super-admin project only: set APP_URL to this portal's URL
NEXT_PUBLIC_APP_NAME=CognexiaAI Super Admin
NEXT_PUBLIC_APP_URL=https://super-admin.your-app.vercel.app

NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SYSTEM_HEALTH=true
